# PostgreSQL
POSTGRES_USER=netmind
POSTGRES_PASSWORD=netmind_password
POSTGRES_DB=netmind_db
DB_PORT=5432

# Database URL (used by both TypeScript and Python backends)
DATABASE_URL=postgresql://netmind:netmind_password@postgres:5432/netmind_db

# CRM Backend (Python/FastAPI)
BACKEND_PORT=8000
API_PREFIX=/api
SESSION_SECRET=your-secret-key-change-in-production
LITELLM_BASE_URL=http://host.docker.internal:4000
LITELLM_MASTER_KEY=sk-1234

# Default Admin Account
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@crm.local
ADMIN_PASSWORD=admin123
ADMIN_FULL_NAME=System Admin

# CRM Frontend (React/Vite)
BASE_PATH=/
# VITE_INTERNAL_PORT is the port Vite runs on inside the container (aliased to PORT)
VITE_INTERNAL_PORT=5173

# NGINX (Reverse Proxy)
NGINX_PORT=5174
# CRM_API_URL is solely for nginx proxy routing (not directly injected into the React code in Docker)
CRM_API_URL=http://crm-backend:8000
# Base path under which the frontend queries the API via Nginx
VITE_API_BASE=/api

# SSO Configuration (Viettel auth.viettel.vn)
SSO_AUTH_URL=https://auth.viettel.vn/auth/login
SSO_LOGOUT_URL=https://auth.viettel.vn/auth/logout
SSO_APP_CODE=netmind
SSO_SERVICE_URL=https://netmind.viettel.vn/gateway/login
SSO_TICKET_API_URL=https://netmind.viettel.vn/vtnet-assistant/v1/api/ai/getUserInfoFromSsoTicket
# Replace with the actual fixed Bearer token provided by Viettel
SSO_TICKET_API_BEARER=